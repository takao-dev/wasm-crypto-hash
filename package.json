{
  "name": "wasm-crypto-hash",
  "version": "4.12.0",
  "description": "Standalone WebAssembly-based digest and checksum utilities for browsers and Node.js (MD4, MD5, SHA-1, SHA-2, SHA-3, Keccak, BLAKE2, BLAKE3, PBKDF2, Argon2, bcrypt, scrypt, Adler-32, CRC32, CRC32C, RIPEMD-160, HMAC, xxHash, SM3)",
  "main": "dist/index.umd.js",
  "module": "dist/index.esm.js",
  "types": "dist/lib/index.d.ts",
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "build:clang": "node ./scripts/build.mjs --clang-only",
    "sign:kms:sdk": "node ./scripts/sign_wasm_kms_sdk.js",
    "lint": "npx @biomejs/biome check lib test",
    "prepublishOnly": "node ./scripts/build.mjs",
    "test": "node --expose-gc ./node_modules/.bin/jest --coverage --logHeapUsage",
    "bench:prod:generate": "node ./scripts/generate_signed_wasm_local.js",
    "bench:prod": "node ./examples/bench/prod_bench.js",
    "webpack": "node webpack/webpack.js"
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/takaodev/wasm-crypto-hash.git"
  },
  "keywords": [
    "hash",
    "wasm",
    "webassembly",
    "md5",
    "adler-32",
    "crc32",
    "crc64",
    "sha-1",
    "sha-2",
    "sha-3",
    "xxhash",
    "keccak",
    "ripemd",
    "hmac",
    "pbkdf2",
    "blake2",
    "blake2b",
    "blake2s",
    "blake3",
    "fast",
    "hashing",
    "browser",
    "key",
    "derivation",
    "password",
    "md4",
    "sha",
    "sha1",
    "sha2",
    "sha224",
    "sha-224",
    "sha256",
    "sha-256",
    "sha384",
    "sha-384",
    "sha512",
    "sha-512",
    "sha3",
    "sha3-224",
    "sha3-256",
    "sha3-384",
    "sha3-512",
    "xxhash32",
    "xxhash64",
    "ripemd160",
    "argon2",
    "argon2i",
    "argon2d",
    "argon2id",
    "scrypt",
    "bcrypt",
    "sm3"
  ],
  "bugs": {
    "url": "https://github.com/takaodev/wasm-crypto-hash/issues"
  },
  "homepage": "https://github.com/takaodev/wasm-crypto-hash#readme",
  "author": "Dani Biró <danibiro93@gmail.com> (https://danibiro.com)",
  "license": "MIT",
  "overrides": {
    "picomatch": "4.0.4",
    "serialize-javascript": "7.0.5",
    "minimist": "1.2.6",
    "semver": "7.8.1",
    "minimatch": "3.1.4"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/estree": "^1.0.9",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.19.19",
    "binaryen": "^120.0.0",
    "jest": "^29.7.0",
    "rollup": "^4.27.3",
    "rollup-plugin-gzip": "^4.2.0",
    "rollup-plugin-license": "^3.7.1",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typedoc": "^0.28.19",
    "typescript": "^5.9.3"
  }
  ,
  "dependencies": {
    "@aws-sdk/client-kms": "^3.400.0",
    "@google-cloud/kms": "^3.6.0"
  }
}
